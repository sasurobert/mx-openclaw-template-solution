{
    "name": "mx-openclaw-template-solution",
    "version": "1.0.0",
    "description": "MultiversX OpenClaw Agent Template — Zero-to-Production in 5 Minutes",
    "author": "MultiversX",
    "license": "MIT",
    "private": true,
    "scripts": {
        "launch": "bash launch.sh",
        "launch:local": "bash launch.sh --local",
        "setup": "bash scripts/setup.sh",
        "generate-wallet": "npx ts-node scripts/generate_wallet.ts",
        "register": "npx ts-node scripts/register.ts",
        "balance": "npx ts-node scripts/check_balance.ts",
        "fund": "npx ts-node scripts/fund.ts",
        "update-manifest": "npx ts-node scripts/update_manifest.ts",
        "pin-manifest": "npx ts-node scripts/pin_manifest.ts",
        "dev": "bash scripts/dev.sh",
        "build": "bash scripts/build.sh",
        "provision": "bash infra/provision.sh",
        "deploy": "bash infra/deploy.sh",
        "destroy": "bash infra/destroy.sh",
        "logs": "bash infra/logs.sh",
        "test": "npm run test:scripts && npm run test:backend && npm run test:frontend",
        "test:scripts": "jest --config jest.scripts.config.js --forceExit",
        "test:e2e": "jest --config jest.e2e.config.js --forceExit --detectOpenHandles",
        "test:backend": "cd backend && npm test",
        "test:frontend": "cd frontend && npm test",
        "typecheck": "tsc --noEmit",
        "typecheck:scripts": "tsc --project tsconfig.json --noEmit"
    },
    "dependencies": {
        "@multiversx/sdk-core": "^15.0.0",
        "axios": "^1.7.0",
        "dotenv": "^16.4.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^22.0.0",
        "jest": "^29.7.0",
        "supertest": "^7.0.0",
        "@types/supertest": "^6.0.0",
        "ts-jest": "^29.2.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}